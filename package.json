{
  "name": "current",
  "version": "0.1.0",
  "private": true,
  "description": "Current - local-first Discord-style chat and voice with atproto auth",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter @current/server dev",
    "dev:workspace": "turbo run dev --parallel",
    "launch:server": "node scripts/start-current-server.mjs",
    "launch:server:dev": "node scripts/start-current-server.mjs --mode=dev",
    "launch:server:lan": "node scripts/start-current-server.mjs --instance=lan",
    "launch:server:lan:dev": "node scripts/start-current-server.mjs --instance=lan --mode=dev",
    "launch:server:lan:normal": "node scripts/start-current-server.mjs --instance=lan --mode=normal",
    "launch:server:normal": "node scripts/start-current-server.mjs --mode=normal",
    "lint": "turbo run lint",
    "release:server": "node scripts/build-server-release.mjs",
    "update:server": "node scripts/update-current-server.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "setup": "bash scripts/bootstrap.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2"
    },
    "onlyBuiltDependencies": [
      "electron",
      "mediasoup"
    ]
  }
}
