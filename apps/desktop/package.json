{
  "name": "@current/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @current/web dev & pnpm --filter @current/desktop build && wait-on tcp:5173 && CURRENT_DEV=1 electron ./dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start": "CURRENT_DEV=0 electron ./dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "electron": "^38.4.0"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "wait-on": "^9.0.3"
  }
}
